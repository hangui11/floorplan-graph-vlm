@inproceedings{villmsgraphics2025,
author = {Nardoni, Valeria and Ali, Kimiya Noor and Ziran, Zahra and Marinai, Simone},
title = {Visual Large Language Models for Graphics Understanding: A Case Study on Floorplan Images},
year = {2025},
isbn = {9798400713514},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3704268.3748681},
doi = {10.1145/3704268.3748681},
abstract = {This study explores the use of Vision Large Language Models (VLLMs) for identifying items in complex graphical documents. In particular, we focus on looking for furniture objects (e.g. beds, tables, and chairs) and structural items (doors and windows) in floorplan images. We evaluate one object detection model (YOLO) and state-of-the-art VLLMs on two datasets featuring diverse floorplan layouts and symbols. The experiments with VLLMs are performed with a zero-shot setting, meaning the models are tested without any training or fine-tuning, as well as with a few-shot approach, where examples of items to be found in the image are given to the models in the prompt. The results highlight the strengths and limitations of VLLMs in recognizing architectural elements, providing guidance for future research in the use multimodal vision-language models for graphics recognition.},
booktitle = {Proceedings of the 2025 ACM Symposium on Document Engineering},
articleno = {29},
numpages = {4},
keywords = {Few-shot Prompting, Graphics Recognition, Visual Large Language Models, Zero-shot Prompting},
location = {Nottingham, United Kingdom},
series = {DocEng '25}
}