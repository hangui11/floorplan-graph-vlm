# ============================================================
#  TFM — Floor Plan to Housing Graph Pipeline
#  .gitignore
# ============================================================

# ---------- Heavy artefacts (NEVER commit) ----------
# Model weights (~8 GB) — re-download via `python download_model.py`
models/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.onnx
*.gguf

# Dataset images (~922 MB) — distributed separately, not part of code
JPG/

# Generated pipeline outputs — recreated by running the pipeline
outputs/

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Virtual envs
venv/
.venv/
env/
.env

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------- LaTeX (report/) ----------
report/*.aux
report/*.bbl
report/*.bcf
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.lof
report/*.lot
report/*.out
report/*.run.xml
report/*.synctex.gz
report/*.toc
report/*.xdv
report/_minted-*/
report/_markdown_*/

# Compiled PDF is kept in the repo as a snapshot of the thesis.

# ---------- IDE / editor ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---------- Secrets ----------
.env
.env.local
*.pem
*.key
secrets.json

# ---------- Local logs / scratch ----------
*.log
scratch/
tmp/

# ---------- Project-specific ----------
# Local Claude Code working notes — not part of the public repo
CLAUDE.md
